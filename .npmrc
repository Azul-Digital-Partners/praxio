auto-install-peers=true

# For Praxio Electron packaging: ensure both darwin arches' optional binary
# deps (embedded-postgres per-arch packages, etc.) install on either host so
# we can produce a working x64 DMG on Apple Silicon. See AZU-1828.
supported-architectures.os[]=darwin
supported-architectures.cpu[]=x64
supported-architectures.cpu[]=arm64
