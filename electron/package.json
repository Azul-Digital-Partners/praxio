{
  "name": "@paperclipai/electron",
  "productName": "Praxio",
  "version": "0.1.0",
  "private": true,
  "description": "Praxio desktop shell (Electron) — boots the Praxio server and renders the UI in a native window.",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "start": "electron dist/main.mjs",
    "dev": "pnpm run build && electron dist/main.mjs",
    "dist": "pnpm run build && cd .. && electron-builder --config electron-builder.yml",
    "dist:mac": "pnpm run build && cd .. && electron-builder --config electron-builder.yml --mac",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@cursor/sdk": "^1.0.12",
    "@embedded-postgres/darwin-arm64": "18.1.0-beta.16",
    "@embedded-postgres/darwin-x64": "18.1.0-beta.16",
    "embedded-postgres": "^18.1.0-beta.16",
    "hermes-paperclip-adapter": "^0.2.0",
    "jsdom": "^28.1.0",
    "pino": "^9.6.0",
    "pino-abstract-transport": "^2.0.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "pino-std-serializers": "^7.0.0",
    "real-require": "^0.2.0",
    "sharp": "^0.34.5",
    "thread-stream": "^3.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@paperclipai/server": "workspace:*",
    "@types/node": "^22.10.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.3"
  }
}
