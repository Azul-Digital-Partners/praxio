# Copy to terraform.tfvars or supply via -var-file at apply time.
# Do NOT commit terraform.tfvars with real values — only the example lives in git.

region            = "us-east-1"
bucket_name       = "praxio-downloads"
domain_name       = "downloads.praxio.app"

# DNS provider for praxio.app. Pick one:
#   "external"  — DNS lives at Cloudflare / Namecheap / something else. The
#                  module emits the CNAMEs you need to add manually.
#   "route53"   — Route53 hosts the zone. Set route53_zone_id below.
dns_provider     = "external"
route53_zone_id  = ""

github_repository  = "Azul-Digital-Partners/praxio"
github_environment = "praxio-release"
release_prefix     = "stable/"

tags = {
  Owner   = "praxio-packaging"
  CostCap = "100usd-monthly"
}
